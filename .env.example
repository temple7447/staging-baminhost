# API Configuration
VITE_BASE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Frontend URL for Paystack Callbacks
# This is where Paystack will redirect after payment
VITE_FRONTEND_URL=http://localhost:5173

# Authentication
VITE_JWT_SECRET_KEY=your_jwt_secret_key_here

# Payment Gateway Configuration

# Paystack Public Key - Get from https://paystack.com/dashboard/settings/developer
# Used for client-side payment processing (Paystack only)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Note: Never commit real keys to version control
# Use different keys for development, staging, and production environments
